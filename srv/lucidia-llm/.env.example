# Lucidia LLM Bridge — environment variables
# Copy to srv/lucidia-llm/.env and adjust as needed.

# Point to your local Ollama (or other OpenAI-compatible) server.
# When unset the bridge runs in stub/echo mode (no GPU required).
LUCIDIA_BACKEND_URL=http://127.0.0.1:11434

# The model name to request from the backend.
LUCIDIA_BACKEND_MODEL=llama3
