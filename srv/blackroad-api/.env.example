# BlackRoad API example overrides
# Copy to srv/blackroad-api/.env and adjust as needed.
PORT=4000
DB_PATH=./blackroad.db
# LLM_URL points to the lucidia-llm bridge running on your own infrastructure.
# All AI/LLM traffic is routed exclusively through this URL.
# Do NOT set OPENAI_API_KEY or ANTHROPIC_API_KEY here — use the lucidia bridge instead.
LLM_URL=http://127.0.0.1:4010/api/llm/chat
# Ollama (local LLM — no external API keys needed)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
IPFS_API=http://127.0.0.1:5001
TRUTH_TOPIC=truth.garden/v1/announce
BACKPLANE_URL=http://127.0.0.1:4000
LED_DEVICE_ID=pi-01
TRUTH_PIN_CONCURRENCY=2
